<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SmyruRGB.Views"
        x:Class="SmyruRGB.MainWindow"
    WindowStartupLocation="Manual"
        Title="SmyruRGB">

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <Border Padding="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="14">
                <Image Width="96"
                       Height="96"
                       Source="avares://SmyruRGB/Assets/Images/elephant-128x128.png" />

                <StackPanel Spacing="6" VerticalAlignment="Center">
                    <TextBlock FontSize="28" FontWeight="Bold" Text="SmyruRGB" />
                <TextBlock Opacity="0.75" Text="Control panel for effects, devices, controllers, and app settings." />
                </StackPanel>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Effects">
                <views:EffectsTabView />
            </TabItem>

            <TabItem Header="Canvas">
                <views:CanvasTabView />
            </TabItem>

            <TabItem Header="Devices">
                <views:DevicesTabView />
            </TabItem>

            <TabItem Header="Controllers">
                <views:ControllersTabView />
            </TabItem>

            <TabItem Header="Settings">
                <views:SettingsTabView />
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Padding="0,16,0,0"
                HorizontalAlignment="Right">
            <TextBlock Opacity="0.65"
                       Text="{Binding AppVersion}" />
        </Border>
    </Grid>
</Window>
