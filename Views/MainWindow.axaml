<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SmyruRGB.Views"
    x:Class="SmyruRGB.MainWindow"
        Width="720" Height="640"
        Title="SmyruRGB">

    <Grid RowDefinitions="Auto,*" Margin="20">
        <Border Padding="0,0,0,16">
            <StackPanel Spacing="6">
                <TextBlock FontSize="28" FontWeight="Bold" Text="SmyruRGB" />
                <TextBlock Opacity="0.75" Text="Control panel for effects, devices, controllers, and app settings." />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Effects">
                <views:EffectsTabView />
            </TabItem>

            <TabItem Header="Devices">
                <views:DevicesTabView />
            </TabItem>

            <TabItem Header="Controllers">
                <views:ControllersTabView />
            </TabItem>

            <TabItem Header="Settings">
                <views:SettingsTabView />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
